# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Public production URL used by future server-side checkout,
# Razorpay callbacks, and self-referential links.
APP_URL="https://your-production-domain.com"

# Supabase browser client values. These are safe to expose to the frontend.
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-or-anon-key"

# Server-only values. Never expose these through VITE_ variables or browser code.
# Current Vite-only catalog/admin dashboard does not need these in browser code.
SUPABASE_SECRET_KEY="sb_secret_your-server-only-secret-key"
# Legacy fallback only, for projects still using JWT-based service_role keys.
# SUPABASE_SERVICE_ROLE_KEY="your-server-only-legacy-service-role-key"
RAZORPAY_KEY_ID="rzp_test_or_live_key_id"
RAZORPAY_KEY_SECRET="your-server-only-razorpay-secret"
RAZORPAY_WEBHOOK_SECRET="your-server-only-razorpay-webhook-secret"
RESEND_API_KEY="re_your-server-only-resend-key"
